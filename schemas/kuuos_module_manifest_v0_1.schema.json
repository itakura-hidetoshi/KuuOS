{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/itakura-hidetoshi/KuuOS/schemas/kuuos_module_manifest_v0_1.schema.json",
  "title": "KuuOS Module Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "capability",
    "status",
    "authority_surface",
    "provides",
    "requires",
    "owns",
    "must_not_own",
    "subscribes",
    "emits",
    "implementation",
    "validator",
    "rollback"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$"},
    "capability": {"type": "string", "minLength": 3},
    "status": {"enum": ["active", "shadow", "deprecated", "quarantined"]},
    "authority_surface": {"enum": ["candidate_only", "read_only", "advisory", "bounded_effect"]},
    "provides": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "requires": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "owns": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "must_not_own": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "subscribes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "emits": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "implementation": {"type": "string", "minLength": 1},
    "validator": {"type": "string", "minLength": 1},
    "rollback": {"type": "string", "minLength": 1},
    "documentation": {"type": "string"},
    "formal_module": {"type": "string"}
  }
}
