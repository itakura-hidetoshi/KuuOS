    "aggregation": "plurality_preserving_hull",
    "point_estimate_required": false
  },
  "preserved_surfaces": [
    "source_belief_state_digest",
    "source_context_id",
    "declared_path",
    "transported_interval",
    "transport_reliability",
    "curvature",
    "cocycle_defect",
    "holonomy_residual",
    "qi_history_compatibility",
    "evidence_digests",
    "counterevidence_digests",
    "conflict_index"
  ],
  "routes": [
    "CANDIDATE",
    "OBSERVE",
    "HOLD",
    "REPAIR",
    "REJECT",
    "QUARANTINE"
  ],
  "persistence": {
    "genesis": "belief-transport-genesis.json",
    "ledger": "belief-transport-ledger.jsonl",
    "snapshot": "belief-transport-snapshot.json",
    "lock": ".belief-transport.lock",
    "append_only": true,
    "snapshot_derived_from_ledger": true,
    "atomic_snapshot": true,
    "replay_idempotent": true,
    "holonomy_chain_preserved": true
  },
  "activation_boundary": {
    "mission_cycle_source": "kuuos_autonomous_mission_cycle_kernel_v0_21",
    "candidate_route_required": true,
    "mission_phase": "replan",
    "future_only": true,
    "memory_overwrite": false,
    "next_plan_basis_digest_required": true
  },
  "non_authority": {
    "truth_authority_granted": false,
    "execution_authority_granted": false,
    "proof_authority_granted": false,
    "clinical_authority_granted": false,
    "institutional_authority_granted": false,
    "global_context_authority_granted": false,
    "memory_overwrite_authority_granted": false,
    "graph_route_authority_granted": false
  }
}
