      "one_minus_curvature",
      "one_minus_cocycle_defect",
      "one_minus_holonomy_residual",
      "qi_history_compatibility"
    ],
    "interval_map": {
      "lower": "reliability * source_lower",
      "upper": "reliability * source_upper + (1 - reliability)"
