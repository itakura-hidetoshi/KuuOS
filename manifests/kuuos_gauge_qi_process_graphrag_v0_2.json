{
  "version": "kuuos_gauge_qi_process_graphrag_v0_2",
  "source_kernel": "kuuos_gauge_qi_process_graphrag_v0_1",
  "scope": {
    "one_lineage": true,
    "one_query": true,
    "persistent_global_context_graph": false,
    "network_retrieval_performed": false,
    "execution_performed": false
  },
  "persistence": {
    "genesis": "graph-rag-genesis.json",
    "ledger": "graph-rag-ledger.jsonl",
    "snapshot": "graph-rag-snapshot.json",
    "lock": ".graph-rag.lock",
    "append_only": true,
    "restart_recovery": true,
    "idempotent_replay": true,
    "snapshot_derived_from_ledger": true,
    "snapshot_repair_from_verified_ledger_only": true
