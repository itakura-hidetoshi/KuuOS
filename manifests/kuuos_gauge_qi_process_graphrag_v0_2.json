    "belief_os_candidate_required": true,
    "belief_commit_receipt_required": true,
    "mission_phase": "replan",
    "mission_cycle_state_digest_required": true,
    "replan_receipt_digest_required": true,
    "next_plan_basis_digest_required": true,
    "decision_commit_granted": false,
    "execution_authority_granted": false,
    "clinical_authority_granted": false,
    "theorem_authority_granted": false
  },
  "routes": [
    "CANDIDATE",
    "OBSERVE",
    "HOLD",
    "REPAIR",
    "QUARANTINE"
  ]
}
