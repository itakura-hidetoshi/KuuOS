{
  "schema_version": "0.2",
  "policy": {
    "boundaries": [
      "calculated Git object candidate != object database materialization",
      "candidate commit OID != created commit",
      "commit candidate certificate != reference mutation authority",
      "unsigned candidate != signed object"
    ]
  },
  "full_audit_paths": [
    "ci/check_registry.d/repository_commit_candidate_v0_93.json"
  ],
