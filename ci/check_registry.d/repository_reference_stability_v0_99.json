{
  "schema_version": "0.2",
  "policy": {
    "boundaries": [
      "receipt confirmation != later stability",
      "exact tip retention != descendant reachability",
      "object database reachability != reflog history",
      "present-state retention != proof of all historical operations",
      "branch reachability != push authority"
    ]
  },
  "full_audit_paths": [
    "ci/check_registry.d/repository_reference_stability_v0_99.json"
  ],
  "checks": {
    "repository-reference-stability-v099": {
      "name": "KuuOS repository reference stability and reachability v0.99",
      "runner": "python",
      "command": "python3 -m unittest -v tests.test_kuuos_repository_reference_stability_v0_99",
      "group": "self-organization",
      "tier": "integration",
      "paths": [
        "runtime/kuuos_repository_reference_stability*_v0_99.py",
        "runtime/kuuos_reference_stability_strict_v099.py",
        "runtime/kuuos_repository_reference_update_receipt*_v0_98.py",
        "tests/test_kuuos_repository_reference_stability_v0_99.py",
        "scripts/check_kuuos_live_v099.py",
        "KUUOS_REPOSITORY_REFERENCE_STABILITY_REACHABILITY_v0_99.md",
        "manifests/kuuos_ref_stability_v099.json"
      ],
      "depends_on": [
        "repository-reference-update-receipt-v098"
      ],
      "timeout_minutes": 25,
      "pr_required": true,
      "full_audit_member": true
    }
  }
}
