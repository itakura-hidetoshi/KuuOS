{
  "schema_version": "0.2",
  "policy": {
    "boundaries": [
      "Git object observation != remote history attestation",
      "read-only revision adapter != repository write authority"
    ]
  },
  "full_audit_paths": [
    "ci/check_registry.d/repository_git_revision_adapter_v0_83.json"
  ],
  "checks": {
    "repository-git-revision-v083": {
      "name": "KuuOS repository Git revision adapter v0.83",
      "runner": "python",
      "command": "python3 scripts/check_kuuos_repository_git_revision_adapter_v083.py",
      "group": "self-organization",
      "tier": "integration",
      "paths": [
        "runtime/kuuos_repository_git_revision*_v0_83.py",
        "runtime/kuuos_repository_certificate_chain*_v0_82.py",
        "tests/test_kuuos_repository_git_revision_adapter_v0_83.py",
        "scripts/check_kuuos_repository_git_revision_adapter_v083.py",
        "scripts/check_kuuos_repository_live_v079.py",
        "docs/KUUOS_REPOSITORY_GIT_REVISION_ADAPTER_v0_83.md",
        "manifests/kuuos_repository_git_revision_adapter_v0_83.json"
      ],
      "depends_on": [
        "repository-certificate-chain-v082"
      ],
      "timeout_minutes": 20,
      "pr_required": true,
      "full_audit_member": true
    }
  }
}
