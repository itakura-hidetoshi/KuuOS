        "runtime/*checkpoint_evidence_envelope*v1_12.py",
        "runtime/v112_checkpoint_evidence_envelope*.py",
        "tests/test_kuuos_checkpoint_evidence_envelope_v1_12.py",
        "formal/KUOS/WORLD/KuuOSCheckpointEvidenceEnvelopeV1_12.lean",
