{
  "schema_version": "0.2",
  "policy": {
    "boundaries": [
      "checkpoint authorization != checkpoint execution",
      "modeled checkpoint transition != live Git mutation",
      "checkpoint creation != checkpoint overwrite",
      "checkpoint creation != branch or tag mutation",
      "local checkpoint creation != push authority"
    ]
  },
  "full_audit_paths": [
    "ci/check_registry.d/repository_atomic_checkpoint_creation_v1_02.json"
  ],
  "checks": {
    "repository-atomic-checkpoint-creation-v102": {
      "name": "KuuOS repository atomic checkpoint creation v1.02",
      "runner": "python",
      "command": "python3 -m unittest -v tests.test_kuuos_repository_atomic_checkpoint_creation_v1_02",
      "group": "self-organization",
      "tier": "integration",
      "paths": [
        "runtime/kuuos_repository_atomic_checkpoint_creation*_v1_02.py",
        "runtime/kuuos_repository_local_frontier_checkpoint_authorization*_v1_01.py",
        "runtime/kuuos_checkpoint_authorization_strict_v101.py",
        "tests/test_kuuos_repository_atomic_checkpoint_creation_v1_02.py",
        "scripts/check_kuuos_live_v102.py",
        "KUUOS_REPOSITORY_ATOMIC_CHECKPOINT_CREATION_v1_02.md",
        "manifests/kuuos_atomic_checkpoint_creation_v102.json"
      ],
      "depends_on": [
        "repository-checkpoint-authorization-v101"
      ],
      "timeout_minutes": 30,
      "pr_required": true,
      "full_audit_member": true
    }
  }
}
