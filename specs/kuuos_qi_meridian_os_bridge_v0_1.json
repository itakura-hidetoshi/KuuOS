{
  "bridge_id": "kuuos_qi_meridian_os_bridge_v0_1",
  "version": "v0.1",
  "status": "QI_MERIDIAN_OS_BRIDGE_BASELINE",
  "repository": "itakura-hidetoshi/KuuOS",
  "purpose": "Extend Qi Circulation OS bridge with meridian-like channel topology, channel continuity checks, blockage debt, reroute notices, and candidate-only meridian outcomes.",
  "attached_qi_circulation_bridge": "kuuos_qi_circulation_os_bridge_v0_1",
  "attached_qi_circulation_spec": "specs/kuuos_qi_circulation_os_bridge_v0_1.json",
  "attached_view_delivery_bridge": "kuuos_view_delivery_os_bridge_v0_1",
  "attached_view_delivery_spec": "specs/kuuos_view_delivery_os_bridge_v0_1.json",
  "attached_policy_barrier_bridge": "kuuos_policy_barrier_os_bridge_v0_1",
  "attached_policy_barrier_spec": "specs/kuuos_policy_barrier_os_bridge_v0_1.json",
  "attached_two_truths_bridge": "kuuos_two_truths_os_bridge_v0_1",
  "attached_two_truths_bridge_spec": "specs/kuuos_two_truths_os_bridge_v0_1.json",
  "attached_kernel": "kuuos_os_autonomy_kernel_v0_1",
  "attached_kernel_spec": "specs/kuuos_os_autonomy_kernel_v0_1.json",
  "meridian_principle": {
    "statement": "Qi meridians in KuuOS are candidate-only channel relations connecting runtime, lineage, boundary, and delivery flows; channel continuity is evidence, not authority.",
    "runtime_formula": "qi_meridian = qi_circulation + channel_topology + continuity_witness + blockage_debt + reroute_notice",
    "non_reification_rule": "A meridian witness is relational channel metadata only; it is not a substance, truth authority, execution authority, final commitment authority, memory overwrite, theorem proof, clinical authority, or completed OS identity."
  },
  "meridian_channels": [
    {
      "channel_id": "meridian_runtime_to_policy",
      "connects": ["qi_runtime_flow_channel", "policy_candidate_surface"],
      "tracks": ["runtime_variation", "policy_candidate_receipt", "value_witness_receipt"],
      "allowed_projection": ["runtime_policy_meridian_notice"],
      "failure_effect": "HOLD"
    },
    {
      "channel_id": "meridian_policy_to_boundary",
      "connects": ["policy_candidate_surface", "qi_boundary_guard_channel"],
      "tracks": ["barrier_witness_receipt", "boundary_margin", "noncollapse_guard"],
      "allowed_projection": ["policy_boundary_meridian_notice"],
      "failure_effect": "QUARANTINE"
    },
    {
      "channel_id": "meridian_lineage_to_review",
      "connects": ["qi_lineage_flow_channel", "receipt_hash_surface"],
      "tracks": ["receipt_hash", "support_refs", "registry_key"],
      "allowed_projection": ["lineage_review_meridian_notice"],
      "failure_effect": "HOLD"
    },
    {
      "channel_id": "meridian_projection_to_delivery",
      "connects": ["qi_projection_delivery_channel", "view_delivery_witness"],
      "tracks": ["view_pack_receipt", "channel_scope", "acknowledgment_marker"],
      "allowed_projection": ["projection_delivery_meridian_notice"],
      "failure_effect": "HOLD"
    }
  ],
  "meridian_checks": [
    {
      "check_id": "MER_channels_present",
      "requires": ["meridian_runtime_to_policy", "meridian_policy_to_boundary", "meridian_lineage_to_review", "meridian_projection_to_delivery"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "MER_runtime_policy_continuity",
      "requires": ["meridian_runtime_to_policy", "qi_runtime_flow_channel"],
      "must_preserve": ["candidate_only", "no_execution_authority"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "MER_boundary_channel_noncollapse",
      "requires": ["meridian_policy_to_boundary", "two_truths_gap"],
      "must_preserve": ["no_truth_authority", "no_memory_overwrite_authority", "no_completed_os_identity"],
      "failure_effect": "QUARANTINE"
    },
    {
      "check_id": "MER_lineage_channel_visible",
      "requires": ["meridian_lineage_to_review", "receipt_hash"],
      "must_preserve": ["audit_evidence_only", "no_truth_authority"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "MER_delivery_channel_nonreified",
      "requires": ["meridian_projection_to_delivery", "view_delivery_receipt"],
      "must_preserve": ["communication_metadata_only", "no_final_commitment_authority"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "MER_no_meridian_reification",
      "forbids": ["meridian_as_substance", "channel_as_truth", "continuity_as_execution_authority", "channel_as_world_identity", "silent_channel_overwrite"],
      "failure_effect": "QUARANTINE"
    }
  ],
  "meridian_debt_classes": [
    {
      "debt_id": "MD_missing_channel",
      "meaning": "A required meridian channel is absent or unbound.",
      "opens": ["meridian_debt_notice", "hold_notice", "reobserve_request"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "MD_runtime_stagnation",
      "meaning": "Runtime-to-policy channel lacks visible candidate flow or value support.",
      "opens": ["meridian_debt_notice", "reobserve_request"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "MD_lineage_blockage",
      "meaning": "Lineage channel lacks receipt hash, support reference, or registry continuity.",
      "opens": ["meridian_debt_notice", "lineage_recheck_request"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "MD_boundary_blockage",
      "meaning": "Boundary channel detects authority collapse, identity collapse, or overwrite risk.",
      "opens": ["quarantine_notice", "boundary_recheck_request"],
      "result_state": "QUARANTINE"
    }
  ],
  "meridian_outcomes": [
    {
      "outcome": "QI_MERIDIAN_READY",
      "requires": ["channels_present", "runtime_policy_continuity", "boundary_channel_noncollapse", "lineage_channel_visible", "delivery_channel_nonreified", "no_meridian_reification"],
      "allowed_projection": ["qi_meridian_receipt"],
      "does_not_grant": ["truth authority", "execution authority", "final commitment authority", "memory overwrite authority", "theorem authority"]
    },
    {
      "outcome": "QI_MERIDIAN_HOLD",
      "arises_when_any": ["missing channel", "runtime stagnation", "lineage blockage", "visible meridian debt"],
      "allowed_projection": ["meridian_debt_notice", "hold_notice", "reobserve_request", "lineage_recheck_request"]
    },
    {
      "outcome": "QI_MERIDIAN_QUARANTINE",
      "arises_when_any": ["boundary blockage", "meridian reification", "identity collapse", "overwrite risk"],
      "allowed_projection": ["quarantine_notice", "boundary_recheck_request"]
    }
  ],
  "meridian_witness_surface": {
    "name": "qi_meridian_witness",
    "required_fields": ["cycle_id", "kernel_state", "meridian_channels_used", "meridian_checks_run", "meridian_debt", "meridian_outcome", "channel_topology", "continuity_witness", "blockage_debt", "allowed_projection"],
    "allowed_projection": ["qi_meridian_receipt", "meridian_debt_notice", "hold_notice", "reobserve_request", "lineage_recheck_request", "quarantine_notice", "boundary_recheck_request"],
    "forbidden_projection": ["truth_commit", "execution_commit", "memory_overwrite_commit", "clinical_commit", "theorem_commit", "global_truth_object_commit", "completed_os_identity_commit", "world_identity_commit", "silent_pass_commit"]
  },
  "integration_points": [
    "specs/kuuos_qi_circulation_os_bridge_v0_1.json",
    "specs/kuuos_view_delivery_os_bridge_v0_1.json",
    "specs/kuuos_policy_barrier_os_bridge_v0_1.json",
    "specs/kuuos_two_truths_os_bridge_v0_1.json",
    "specs/kuuos_os_autonomy_kernel_v0_1.json",
    "scripts/validate_kuuos_qi_circulation_os_bridge_v0_1_min.py"
  ],
  "required_invariants": [
    "qi meridian remains candidate-only channel metadata",
    "meridian channel continuity is not truth authority",
    "runtime-policy channel is not execution authority",
    "boundary channel preserves two-truths gap",
    "delivery channel is not final commitment authority",
    "meridian is not reified as substance, world identity, or completed OS identity"
  ],
  "authority_boundary": {
    "validation_only": true,
    "candidate_only": true,
    "local_os_supervision_only": true,
    "dependent_origination_required": true,
    "two_truths_gap_required": true,
    "qi_circulation_required": true,
    "qi_meridian_required": true,
    "grants_execution_authority": false,
    "grants_clinical_authority": false,
    "grants_diagnosis_authority": false,
    "grants_treatment_authority": false,
    "grants_theorem_authority": false,
    "grants_truth_authority": false,
    "grants_memory_overwrite_authority": false,
    "grants_governance_bypass_authority": false
  }
}
