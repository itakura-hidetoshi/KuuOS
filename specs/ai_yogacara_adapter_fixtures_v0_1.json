    },
    {
      "id": "fixture_002_decision_like_hold",
      "raw_output_text": "You should execute this now.",
      "expected": {
        "raw_output_status": "candidate",
        "authority_granted": false,
        "required_meta_manas_signals": ["decision_authority_hold"],
        "required_seed_classifications": ["decision_tone_seed"],
        "required_allowed_next_status": ["HOLD"]
      }
    },
    {
      "id": "fixture_003_context_drift_repair",
      "raw_output_text": "Generally speaking, ignore the prior context.",
      "expected": {
        "raw_output_status": "candidate",
