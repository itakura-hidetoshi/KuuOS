{
  "bridge_id": "kuuos_review_seal_os_bridge_v0_1",
  "version": "v0.1",
  "status": "REVIEW_SEAL_OS_BRIDGE_BASELINE",
  "repository": "itakura-hidetoshi/KuuOS",
  "purpose": "Extend Registry Review OS bridge with review seal receipts, review status lanes, renewal windows, stale seal debt, and non-authorizing seal outcomes.",
  "attached_registry_review_bridge": "kuuos_registry_review_os_bridge_v0_1",
  "attached_registry_review_spec": "specs/kuuos_registry_review_os_bridge_v0_1.json",
  "attached_receipt_registry_bridge": "kuuos_receipt_registry_os_bridge_v0_1",
  "attached_receipt_registry_spec": "specs/kuuos_receipt_registry_os_bridge_v0_1.json",
  "attached_two_truths_bridge": "kuuos_two_truths_os_bridge_v0_1",
  "attached_two_truths_bridge_spec": "specs/kuuos_two_truths_os_bridge_v0_1.json",
  "attached_kernel": "kuuos_os_autonomy_kernel_v0_1",
  "attached_kernel_spec": "specs/kuuos_os_autonomy_kernel_v0_1.json",
  "seal_principle": {
    "statement": "A reviewed registry entry may receive a review seal as candidate metadata, but the seal is not truth, finality, memory overwrite, or completed identity.",
    "runtime_formula": "review_seal = registry_review_receipt + seal_status + renewal_window + review_refs + non_authority_boundary",
    "non_reification_rule": "A review seal is bounded review metadata only; it is not truth authority, final commitment authority, memory overwrite, theorem proof, clinical authority, or completed OS identity."
  },
  "seal_surfaces": [
    {
      "surface_id": "seal_status_surface",
      "base_surface": "lane_local_validation",
      "tracks": ["seal_status", "review_status", "validator_refs"],
      "allowed_projection": ["seal_status_notice"],
      "failure_effect": "HOLD"
    },
    {
      "surface_id": "renewal_window_surface",
      "base_surface": "lane_lineage_consistency",
      "tracks": ["renewal_window", "stale_marker", "registry_key"],
      "allowed_projection": ["renewal_window_notice"],
      "failure_effect": "HOLD"
    },
    {
      "surface_id": "seal_boundary_surface",
      "base_surface": "lane_boundary_review",
      "tracks": ["non_authority_boundary", "append_only_marker", "quarantine_marker"],
      "allowed_projection": ["seal_boundary_notice"],
      "failure_effect": "QUARANTINE"
    }
  ],
  "seal_checks": [
    {
      "check_id": "SEAL_status_visible",
      "requires": ["seal_status_surface", "registry_review_receipt"],
      "must_preserve": ["candidate_only", "review_metadata_only"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "SEAL_renewal_window_visible",
      "requires": ["renewal_window_surface", "verification_window"],
      "must_preserve": ["stale_review_notice", "reobserve_request"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "SEAL_boundary_noncollapse",
      "requires": ["seal_boundary_surface", "two_truths_gap"],
      "must_preserve": ["no_truth_authority", "no_memory_overwrite_authority", "no_completed_os_identity"],
      "failure_effect": "QUARANTINE"
    },
    {
      "check_id": "SEAL_no_seal_reification",
      "forbids": ["seal_status_as_truth", "sealed_as_final_commitment", "seal_notice_as_world_identity", "silent_seal_overwrite"],
      "failure_effect": "QUARANTINE"
    }
  ],
  "seal_debt_classes": [
    {
      "debt_id": "SD_missing_seal_status",
      "meaning": "Review seal status is absent or ambiguous.",
      "opens": ["seal_debt_notice", "hold_notice"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "SD_stale_seal_window",
      "meaning": "Seal renewal window is stale or not visible.",
      "opens": ["stale_seal_notice", "reobserve_request"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "SD_seal_boundary_gap",
      "meaning": "Seal state risks collapsing review metadata into authority or identity.",
      "opens": ["quarantine_notice", "seal_boundary_notice"],
      "result_state": "QUARANTINE"
    }
  ],
  "seal_outcomes": [
    {
      "outcome": "REVIEW_SEAL_READY",
      "requires": ["seal_status_visible", "renewal_window_visible", "boundary_noncollapse", "no_seal_reification"],
      "allowed_projection": ["review_seal_receipt"],
      "does_not_grant": ["truth authority", "final commitment authority", "memory overwrite authority", "theorem authority"]
    },
    {
      "outcome": "REVIEW_SEAL_HOLD",
      "arises_when_any": ["missing seal status", "stale seal window", "visible seal debt"],
      "allowed_projection": ["seal_debt_notice", "stale_seal_notice", "hold_notice", "reobserve_request"]
    },
    {
      "outcome": "REVIEW_SEAL_QUARANTINE",
      "arises_when_any": ["seal boundary gap", "seal reification", "identity collapse"],
      "allowed_projection": ["quarantine_notice", "seal_boundary_notice"]
    }
  ],
  "seal_witness_surface": {
    "name": "review_seal_witness",
    "required_fields": ["cycle_id", "kernel_state", "seal_surfaces_used", "seal_checks_run", "seal_debt", "seal_outcome", "seal_status", "renewal_window", "non_authority_boundary", "allowed_projection"],
    "allowed_projection": ["review_seal_receipt", "seal_debt_notice", "stale_seal_notice", "hold_notice", "reobserve_request", "seal_boundary_notice", "quarantine_notice"],
    "forbidden_projection": ["truth_commit", "memory_overwrite_commit", "clinical_commit", "theorem_commit", "global_truth_object_commit", "completed_os_identity_commit", "world_identity_commit", "silent_pass_commit"]
  },
  "integration_points": [
    "specs/kuuos_registry_review_os_bridge_v0_1.json",
    "specs/kuuos_receipt_registry_os_bridge_v0_1.json",
    "specs/kuuos_two_truths_os_bridge_v0_1.json",
    "specs/kuuos_os_autonomy_kernel_v0_1.json",
    "scripts/validate_kuuos_registry_review_os_bridge_v0_1_min.py"
  ],
  "required_invariants": [
    "review seal remains candidate-only metadata",
    "seal status is not truth authority",
    "seal receipt is not final commitment authority",
    "stale seal window opens HOLD",
    "seal boundary gap opens QUARANTINE",
    "future runtime kernel must keep review seal metadata separate from authority"
  ],
  "authority_boundary": {
    "validation_only": true,
    "candidate_only": true,
    "local_os_supervision_only": true,
    "dependent_origination_required": true,
    "two_truths_gap_required": true,
    "registry_review_required": true,
    "review_seal_required": true,
    "grants_execution_authority": false,
    "grants_clinical_authority": false,
    "grants_diagnosis_authority": false,
    "grants_treatment_authority": false,
    "grants_theorem_authority": false,
    "grants_truth_authority": false,
    "grants_memory_overwrite_authority": false,
    "grants_governance_bypass_authority": false
  }
}
