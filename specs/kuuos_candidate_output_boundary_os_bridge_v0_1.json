{
  "bridge_id": "kuuos_candidate_output_boundary_os_bridge_v0_1",
  "version": "v0.1",
  "status": "CANDIDATE_OUTPUT_BOUNDARY_OS_BRIDGE_BASELINE",
  "repository": "itakura-hidetoshi/KuuOS",
  "purpose": "Extend Selector Boundary OS bridge with candidate output receipts, output readiness checks, external-facing boundary notices, and a firewall preventing candidate output from becoming final commitment authority.",
  "attached_selector_boundary_bridge": "kuuos_selector_boundary_os_bridge_v0_1",
  "attached_selector_boundary_spec": "specs/kuuos_selector_boundary_os_bridge_v0_1.json",
  "attached_policy_barrier_bridge": "kuuos_policy_barrier_os_bridge_v0_1",
  "attached_policy_barrier_spec": "specs/kuuos_policy_barrier_os_bridge_v0_1.json",
  "attached_two_truths_bridge": "kuuos_two_truths_os_bridge_v0_1",
  "attached_two_truths_bridge_spec": "specs/kuuos_two_truths_os_bridge_v0_1.json",
  "attached_kernel": "kuuos_os_autonomy_kernel_v0_1",
  "attached_kernel_spec": "specs/kuuos_os_autonomy_kernel_v0_1.json",
  "output_principle": {
    "statement": "KuuOS candidate output is a bounded receipt: selector candidates, holds, abstentions, handovers, and quarantines may be exposed as notices but never become final commitment authority.",
    "runtime_formula": "output_candidate = selector_outcome + readiness_witness + audience_boundary + commitment_firewall + output_debt",
    "non_reification_rule": "An output witness is a communication artifact only; it is not truth authority, final commitment authority, memory overwrite, theorem proof, clinical authority, or completed OS identity."
  },
  "output_surfaces": [
    {
      "surface_id": "candidate_receipt_surface",
      "base_surface": "ranking_witness_surface",
      "tracks": ["selector_candidate_receipt", "support_summary", "nonfinal_marker"],
      "allowed_projection": ["candidate_output_receipt"],
      "failure_effect": "HOLD"
    },
    {
      "surface_id": "hold_abstain_surface",
      "base_surface": "abstention_gate_surface",
      "tracks": ["hold_notice", "abstention_notice", "reobserve_request"],
      "allowed_projection": ["hold_abstain_output_notice"],
      "failure_effect": "HOLD"
    },
    {
      "surface_id": "handover_quarantine_surface",
      "base_surface": "handover_boundary_surface",
      "tracks": ["handover_notice", "quarantine_notice", "boundary_recheck_request"],
      "allowed_projection": ["boundary_output_notice"],
      "failure_effect": "QUARANTINE"
    }
  ],
  "output_checks": [
    {
      "check_id": "OUT_candidate_receipt_nonfinal",
      "requires": ["candidate_receipt_surface", "selector_candidate_receipt"],
      "must_preserve": ["candidate_only", "nonfinal_marker"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "OUT_hold_abstain_available",
      "requires": ["hold_abstain_surface", "abstention_notice"],
      "must_preserve": ["hold_notice", "reobserve_request"],
      "failure_effect": "HOLD"
    },
    {
      "check_id": "OUT_boundary_notice_noncollapse",
      "requires": ["handover_quarantine_surface", "handover_boundary_surface"],
      "must_preserve": ["two_truths_gap", "no_truth_authority", "no_completed_os_identity"],
      "failure_effect": "QUARANTINE"
    },
    {
      "check_id": "OUT_commitment_firewall",
      "forbids": ["candidate_output_as_final_commitment", "notice_as_truth", "handover_as_world_identity", "silent_pass_commit"],
      "failure_effect": "QUARANTINE"
    }
  ],
  "output_debt_classes": [
    {
      "debt_id": "OD_missing_nonfinal_marker",
      "meaning": "Candidate output lacks visible non-final status.",
      "opens": ["output_debt_notice", "hold_notice"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "OD_audience_boundary_gap",
      "meaning": "Output audience boundary or allowed projection is unclear.",
      "opens": ["output_debt_notice", "reobserve_request"],
      "result_state": "HOLD"
    },
    {
      "debt_id": "OD_commitment_collapse",
      "meaning": "Candidate output is being treated as final commitment, identity, or truth.",
      "opens": ["quarantine_notice", "boundary_recheck_request"],
      "result_state": "QUARANTINE"
    }
  ],
  "output_outcomes": [
    {
      "outcome": "CANDIDATE_OUTPUT_READY",
      "requires": ["candidate_receipt_nonfinal", "commitment_firewall", "audience_boundary_visible"],
      "allowed_projection": ["candidate_output_receipt"],
      "does_not_grant": ["truth authority", "final commitment authority", "memory overwrite authority", "theorem authority"]
    },
    {
      "outcome": "CANDIDATE_OUTPUT_HOLD",
      "arises_when_any": ["missing nonfinal marker", "audience boundary gap", "visible output debt"],
      "allowed_projection": ["output_debt_notice", "hold_notice", "reobserve_request"]
    },
    {
      "outcome": "CANDIDATE_OUTPUT_QUARANTINE",
      "arises_when_any": ["commitment collapse", "truth reification", "identity collapse"],
      "allowed_projection": ["quarantine_notice", "boundary_recheck_request"]
    }
  ],
  "output_witness_surface": {
    "name": "candidate_output_boundary_witness",
    "required_fields": ["cycle_id", "kernel_state", "output_surfaces_used", "output_checks_run", "output_debt", "output_outcome", "commitment_firewall", "allowed_projection"],
    "allowed_projection": ["candidate_output_receipt", "output_debt_notice", "hold_notice", "reobserve_request", "boundary_output_notice", "quarantine_notice"],
    "forbidden_projection": ["truth_commit", "memory_overwrite_commit", "clinical_commit", "theorem_commit", "global_truth_object_commit", "completed_os_identity_commit", "world_identity_commit", "silent_pass_commit"]
  },
  "integration_points": [
    "specs/kuuos_selector_boundary_os_bridge_v0_1.json",
    "specs/kuuos_policy_barrier_os_bridge_v0_1.json",
    "specs/kuuos_two_truths_os_bridge_v0_1.json",
    "specs/kuuos_os_autonomy_kernel_v0_1.json",
    "scripts/validate_kuuos_selector_boundary_os_bridge_v0_1_min.py"
  ],
  "required_invariants": [
    "candidate output remains candidate-only",
    "candidate output receipt is not final commitment authority",
    "hold and abstention are valid outputs",
    "handover and quarantine remain notices",
    "commitment firewall preserves two-truths gap",
    "future runtime kernel must keep output separate from final commitment authority"
  ],
  "authority_boundary": {
    "validation_only": true,
    "candidate_only": true,
    "local_os_supervision_only": true,
    "dependent_origination_required": true,
    "two_truths_gap_required": true,
    "selector_boundary_required": true,
    "candidate_output_boundary_required": true,
    "grants_execution_authority": false,
    "grants_clinical_authority": false,
    "grants_diagnosis_authority": false,
    "grants_treatment_authority": false,
    "grants_theorem_authority": false,
    "grants_truth_authority": false,
    "grants_memory_overwrite_authority": false,
    "grants_governance_bypass_authority": false
  }
}
