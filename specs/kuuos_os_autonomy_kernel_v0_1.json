    "external_api_calls_allowed": false,
    "network_required": false,
    "stdlib_only": true
  },
  "target_policy": {
    "default_profile": "smoke",
    "max_cycles": 1,
    "daemon_interval_seconds": 300,
    "module_timeout_seconds": 900,
    "fail_closed": true,
    "halt_on_first_failure": true,
    "state_checkpoint_required": true,
    "audit_hash_chain_required": true,
    "shell_allowed": false,
    "external_api_calls_allowed": false,
    "network_required": false,
    "stdlib_only": true
