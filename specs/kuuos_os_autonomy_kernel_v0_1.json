  "repository": "itakura-hidetoshi/KuuOS",
  "purpose": "Lift KuuOS from a core self-check runner toward an OS-like local supervisor by defining boot, module registry, scheduling, state checkpoint, audit, and fail-closed semantics while using the existing core autonomy runner as the bootstrap host.",
  "bootstrap_host_entrypoint": "scripts/run_kuuos_core_autonomy_v0_1.py",
  "bootstrap_validator_entrypoint": "scripts/validate_kuuos_core_autonomy_contract_v0_1.py",
  "future_kernel_entrypoint": "scripts/run_kuuos_os_autonomy_kernel_v0_1.py",
  "future_validator_entrypoint": "scripts/validate_kuuos_os_autonomy_kernel_v0_1.py",
  "state_schema": "kuuos_os_autonomy_state_v0_1",
  "audit_schema": "kuuos_os_autonomy_audit_event_v0_1",
  "operation_profiles": [
    "smoke",
    "core"
  ],
  "cycle_phases": [
    "boot",
    "load_registry",
    "schedule_modules",
    "run_modules",
    "decide",
    "checkpoint_state",
    "audit"
  ],
  "kernel_states": [
    "PASS",
    "HOLD",
    "REPAIR_PENDING",
    "QUARANTINE"
  ],
  "bootstrap_policy": {
    "current_runnable_host": "scripts/run_kuuos_core_autonomy_v0_1.py",
