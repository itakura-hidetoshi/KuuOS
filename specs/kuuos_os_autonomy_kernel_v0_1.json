  "forbidden_interpretations": [
    "OS autonomy grants execution authority",
    "OS autonomy grants clinical authority",
    "OS autonomy grants treatment authority",
    "OS autonomy grants theorem truth",
    "kernel state grants truth authority",
    "state checkpoint overwrites memory truth",
