      "kind": "validator",
      "profiles": ["core"],
      "entrypoint": "scripts/run_core_governance_full_checks_v0_1.py",
      "timeout_seconds": 900,
      "required": true,
      "authority_boundary": {
        "validation_only": true,
        "candidate_only": true,
        "grants_execution_authority": false,
        "grants_clinical_authority": false,
