{
  "example_version": "qi_automerge_executor_v2_4",
  "purpose": "CI-aware automerge executor with PR merge gate and GitHub tool bridge",
  "input_files": [
    "automerge_packet.json"
  ],
  "output_files": [
    "automerge_receipt.json",
    "automerge_audit.jsonl",
    "pr_merge_gate_packet.json",
    "github_tool_bridge_plan.json"
  ],
  "required_gates": [
    "explicit_automerge_license",
    "expected_head_sha == actual_head_sha",
    "pull_request_not_draft",
    "mergeable",
    "required_checks success",
    "merge_allowed",
    "receipt_written",
    "audit_written"
  ],
  "modes": [
    "mock",
    "real"
  ],
  "status_values": [
    "QI_AUTOMERGE_EXECUTOR_MERGED",
    "QI_AUTOMERGE_EXECUTOR_IDLE",
    "QI_AUTOMERGE_EXECUTOR_BLOCKED"
  ]
}
