{
  "example_version": "qi_circulation_change_router_v2_8",
  "purpose": "route Qi circulation states into the forward change runner",
  "input_files": [
    "circulation_change_route_packet.json"
  ],
  "output_files": [
    "qi_circulation_packet.json",
    "forward_change_packet.json",
    "circulation_change_router_receipt.json",
    "circulation_change_router_audit.jsonl"
  ],
  "routing_actions": [
    "continue_cycle",
    "rebalance_and_continue",
    "reopen_flow"
  ],
  "stop_action": "concrete_stop",
  "status_values": [
    "QI_CIRCULATION_CHANGE_ROUTER_ROUTED",
    "QI_CIRCULATION_CHANGE_ROUTER_IDLE",
    "QI_CIRCULATION_CHANGE_ROUTER_BLOCKED"
  ]
}
