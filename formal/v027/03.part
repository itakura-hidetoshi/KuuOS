structure ExtensionCertificate
    (H : RealHilbertCarrier) (C : DenseOperatorCore H) where
  boundedExtensionExists : Prop
  boundedExtensionWitness : boundedExtensionExists
  coreCompatibility : Prop
  coreCompatibilityWitness : coreCompatibility
  globalSymmetry : Prop
  globalSymmetryWitness : globalSymmetry

