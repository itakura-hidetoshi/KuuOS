/-!
WORLD v0.56: bounded-generator infinite-dimensional Araki Hessian and
Osterwalder-Schrader physical realization.

The calculus kernel below contains no Hessian-identification receipt.  Starting
from the exact first-variation response along bounded self-adjoint exponential
arcs, Lean differentiates once more and proves that the negative mixed Hessian
is the Bogoliubov-Kubo-Mori pairing.

The WORLD layer then transports that proved pairing to the existing vacuum
quantum Fisher metric, Hilbert excitation Gram form, Araki Hessian shadow, and
an Osterwalder-Schrader reflection form representative.

The analytic construction of general relative modular logarithms and unbounded
generator exponential arcs is not silently assumed.  This version states the
literature-supported bounded-generator scope explicitly.
-/

namespace KUOS
namespace WORLD

noncomputable section

/--
The one-dimensional response kernel extracted from an Araki exponential arc.

For generators `k` and `h`, `expectationAlong k h s` is the expectation of `h`
in the exponential arc generated by `k`.  Its derivative at the reference point
is the BKM pairing.  This is the exact analytic input needed after the Araki
first-variation formula has been established.
-/
structure ArakiBoundedExponentialArcKernel where
  Generator : Type
  referenceExpectation : Generator → ℝ
  expectationAlong : Generator → Generator → ℝ → ℝ
  bkmPairing : Generator → Generator → ℝ
  expectationDerivativeAtReference : ∀ k h,
    HasDerivAt (expectationAlong k h) (bkmPairing k h) 0
  bkmSymmetric : ∀ k h, bkmPairing k h = bkmPairing h k
  bkmNonnegative : ∀ h, 0 ≤ bkmPairing h h

namespace ArakiBoundedExponentialArcKernel

variable (A : ArakiBoundedExponentialArcKernel)

/-- The Araki first variation in the second exponential-arc argument. -/
def arakiFirstVariation (k h : A.Generator) (s : ℝ) : ℝ :=
  A.referenceExpectation h - A.expectationAlong k h s

/-- The negative mixed Hessian prescribed by divergence information geometry. -/
def arakiMixedHessian (k h : A.Generator) : ℝ :=
  -deriv (A.arakiFirstVariation k h) 0

/-- The first variation has derivative `-BKM` in the comparison arc. -/
theorem araki_first_variation_hasDerivAt (k h : A.Generator) :
    HasDerivAt (A.arakiFirstVariation k h) (-A.bkmPairing k h) 0 := by
  simpa [arakiFirstVariation] using
    (A.expectationDerivativeAtReference k h).const_sub
      (A.referenceExpectation h)

/--
The infinite-dimensional bounded-generator Araki Hessian equals the BKM metric.
This is a genuine Lean calculus proof from the response derivative, not a stored
claim/proof receipt.
-/
theorem araki_mixed_hessian_eq_bkm (k h : A.Generator) :
    A.arakiMixedHessian k h = A.bkmPairing k h := by
  have hderiv := A.araki_first_variation_hasDerivAt k h
  unfold arakiMixedHessian
  rw [hderiv.deriv]
  simp

theorem araki_mixed_hessian_symmetric (k h : A.Generator) :
    A.arakiMixedHessian k h = A.arakiMixedHessian h k := by
  rw [A.araki_mixed_hessian_eq_bkm, A.araki_mixed_hessian_eq_bkm]
  exact A.bkmSymmetric k h

theorem araki_mixed_hessian_nonnegative (h : A.Generator) :
    0 ≤ A.arakiMixedHessian h h := by
  rw [A.araki_mixed_hessian_eq_bkm]
  exact A.bkmNonnegative h

end ArakiBoundedExponentialArcKernel

structure WorldKuuVacuumArakiHessianPhysicalRealization
    {C : RealHilbertL2Carrier}
    {W : WorldNoncommutativeOperatorAlgebra C}
    [PartialOrder W.Region]
    {B : WorldCStarLocalNetBridge C W}
    {V : WorldVonNeumannBicommutantBridge B}
    {M : WorldStandardFormModularFlowBridge V}
    {R : WorldModularStateKMSRelativeFlowBridge M}
    {E : WorldArakiRelativeEntropyBridge R}
    {P : WorldPetzRecoverySufficiencyBridge E}
    {T : WorldConditionalExpectationTakesakiBridge P}
    {J : WorldJonesBasicConstructionIndexBridge T}
    {S : WorldJonesTowerStandardInvariantBridge J}
    {Q : WorldCanonicalEndomorphismQSystemFrobeniusBridge S}
    {F : WorldBimoduleSectorFusionCategoryBridge Q}
    {Z : WorldModuleCategoryNimrepTubeCenterBridge F}
    {G : WorldGaugeCategoricalIndraNetBridge Z}
    {I : WorldInformationGeometricHigherGaugeBridge G}
    {H : WorldArakiPetzQuantumInformationGeometryBridge I}
    {D : WorldQuantumExponentialDualAffineProjectionBridge H}
    {Vary : WorldQuantumGeodesicMirrorDescentFreeEnergyBridge D}
    {Flow : WorldQuantumGradientJKOEntropyProductionBridge Vary}
    {Mix : WorldQuantumLogSobolevContractivityMixingBridge Flow}
    {K : WorldKuuVacuumOSHilbertCompletionBridge Mix}
    {Central : WorldKuuVacuumCentralReferenceStateBridge K}
    (Geom : WorldKuuVacuumInformationGeometryBridge Central) where
  analyticKernel : ArakiBoundedExponentialArcKernel
  boundedSelfAdjoint : analyticKernel.Generator → Prop
  generatorScope : ∀ h, boundedSelfAdjoint h

  tangentOfGenerator : analyticKernel.Generator → I.Tangent
  physicalObservable : analyticKernel.Generator → B.A
  tangentObservable_eq_physicalObservable : ∀ h,
    H.tangentObservable (tangentOfGenerator h) = physicalObservable h

  bkm_eq_quantumFisher : ∀ i k h,
    analyticKernel.bkmPairing k h =
      H.quantumFisherMetric i (Geom.vacuumParameter i)
        (tangentOfGenerator k) (tangentOfGenerator h)

  positiveTimeRepresentative : analyticKernel.Generator → K.PositiveTimeObservable
  osImage_eq_excitation : ∀ h,
    K.osHilbertIdentification (K.osClass (positiveTimeRepresentative h)) =
      Central.excitationVector (physicalObservable h)

  infiniteDimensionalPhysicalCarrier : InfiniteDimensional ℂ M.H

  sigmaFiniteStandardFormScope : Prop
  sigmaFiniteStandardFormScopeProof : sigmaFiniteStandardFormScope
  faithfulNormalVacuumScope : Prop
  faithfulNormalVacuumScopeProof : faithfulNormalVacuumScope
  boundedArakiExponentialArcScope : Prop
  boundedArakiExponentialArcScopeProof : boundedArakiExponentialArcScope

  noUnboundedGeneratorClaim : Prop
  noUnboundedGeneratorClaimProof : noUnboundedGeneratorClaim
  physicalRealizationNotWorldIdentity : Prop
  physicalRealizationNotWorldIdentityProof : physicalRealizationNotWorldIdentity
  hessianNotTruthAuthority : Prop
  hessianNotTruthAuthorityProof : hessianNotTruthAuthority
  readOnlyAnalyticSidecar : Prop
  readOnlyAnalyticSidecarProof : readOnlyAnalyticSidecar

namespace WorldKuuVacuumArakiHessianPhysicalRealization

