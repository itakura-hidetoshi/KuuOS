variable (Realization :
  WorldKuuVacuumArakiHessianPhysicalRealization Geom)

/-- Physical excitation generated from the information-geometric tangent. -/
def physicalGeneratorExcitation
    (h : Realization.analyticKernel.Generator) : M.H :=
  Geom.vacuumTangentExcitation (Realization.tangentOfGenerator h)

theorem physical_generator_excitation_eq_observable_excitation
    (h : Realization.analyticKernel.Generator) :
    Realization.physicalGeneratorExcitation h =
      Central.excitationVector (Realization.physicalObservable h) := by
  unfold physicalGeneratorExcitation
  unfold WorldKuuVacuumInformationGeometryBridge.vacuumTangentExcitation
  rw [Realization.tangentObservable_eq_physicalObservable h]

theorem physical_generator_excitation_eq_os_image
    (h : Realization.analyticKernel.Generator) :
    Realization.physicalGeneratorExcitation h =
      K.osHilbertIdentification
        (K.osClass (Realization.positiveTimeRepresentative h)) := by
  rw [Realization.physical_generator_excitation_eq_observable_excitation h]
  exact (Realization.osImage_eq_excitation h).symm

theorem araki_hessian_eq_quantum_fisher
    (i : G.Patch) (k h : Realization.analyticKernel.Generator) :
    Realization.analyticKernel.arakiMixedHessian k h =
      H.quantumFisherMetric i (Geom.vacuumParameter i)
        (Realization.tangentOfGenerator k)
        (Realization.tangentOfGenerator h) := by
  rw [Realization.analyticKernel.araki_mixed_hessian_eq_bkm]
  exact Realization.bkm_eq_quantumFisher i k h

theorem araki_hessian_eq_araki_hessian_shadow
    (i : G.Patch) (k h : Realization.analyticKernel.Generator) :
    Realization.analyticKernel.arakiMixedHessian k h =
      H.arakiHessianShadow i (Geom.vacuumParameter i)
        (Realization.tangentOfGenerator k)
        (Realization.tangentOfGenerator h) := by
  calc
    Realization.analyticKernel.arakiMixedHessian k h =
        H.quantumFisherMetric i (Geom.vacuumParameter i)
          (Realization.tangentOfGenerator k)
          (Realization.tangentOfGenerator h) :=
      Realization.araki_hessian_eq_quantum_fisher i k h
    _ = H.arakiHessianShadow i (Geom.vacuumParameter i)
          (Realization.tangentOfGenerator k)
          (Realization.tangentOfGenerator h) :=
      H.quantumFisher_eq_arakiHessian i (Geom.vacuumParameter i)
        (Realization.tangentOfGenerator k)
        (Realization.tangentOfGenerator h)

theorem araki_hessian_eq_physical_excitation_gram
    (i : G.Patch) (k h : Realization.analyticKernel.Generator) :
    Realization.analyticKernel.arakiMixedHessian k h =
      (inner ℂ
        (Realization.physicalGeneratorExcitation k)
        (Realization.physicalGeneratorExcitation h)).re := by
  calc
    Realization.analyticKernel.arakiMixedHessian k h =
        H.quantumFisherMetric i (Geom.vacuumParameter i)
          (Realization.tangentOfGenerator k)
          (Realization.tangentOfGenerator h) :=
      Realization.araki_hessian_eq_quantum_fisher i k h
    _ = (inner ℂ
          (Geom.vacuumTangentExcitation (Realization.tangentOfGenerator k))
          (Geom.vacuumTangentExcitation (Realization.tangentOfGenerator h))).re :=
      (Geom.vacuum_excitation_gram_eq_quantum_fisher i
        (Realization.tangentOfGenerator k)
        (Realization.tangentOfGenerator h)).symm
    _ = (inner ℂ
          (Realization.physicalGeneratorExcitation k)
          (Realization.physicalGeneratorExcitation h)).re := rfl

theorem araki_hessian_eq_os_reflection_form_re
    (i : G.Patch) (k h : Realization.analyticKernel.Generator) :
    Realization.analyticKernel.arakiMixedHessian k h =
      (K.osReflectionForm
        (Realization.positiveTimeRepresentative k)
        (Realization.positiveTimeRepresentative h)).re := by
  rw [Realization.araki_hessian_eq_physical_excitation_gram i k h]
  rw [Realization.physical_generator_excitation_eq_os_image k]
  rw [Realization.physical_generator_excitation_eq_os_image h]
  simpa using congrArg Complex.re
    (K.osClassInner
      (Realization.positiveTimeRepresentative k)
      (Realization.positiveTimeRepresentative h))

theorem araki_hessian_nonnegative
    (h : Realization.analyticKernel.Generator) :
    0 ≤ Realization.analyticKernel.arakiMixedHessian h h :=
  Realization.analyticKernel.araki_mixed_hessian_nonnegative h

theorem physical_carrier_is_infinite_dimensional :
    InfiniteDimensional ℂ M.H :=
  Realization.infiniteDimensionalPhysicalCarrier

theorem exact_scope_package :
    Realization.sigmaFiniteStandardFormScope ∧
    Realization.faithfulNormalVacuumScope ∧
    Realization.boundedArakiExponentialArcScope :=
  ⟨Realization.sigmaFiniteStandardFormScopeProof,
    Realization.faithfulNormalVacuumScopeProof,
    Realization.boundedArakiExponentialArcScopeProof⟩

theorem analytic_boundary_package :
    Realization.noUnboundedGeneratorClaim ∧
    Realization.physicalRealizationNotWorldIdentity ∧
    Realization.hessianNotTruthAuthority ∧
    Realization.readOnlyAnalyticSidecar :=
  ⟨Realization.noUnboundedGeneratorClaimProof,
    Realization.physicalRealizationNotWorldIdentityProof,
    Realization.hessianNotTruthAuthorityProof,
    Realization.readOnlyAnalyticSidecarProof⟩

end WorldKuuVacuumArakiHessianPhysicalRealization
